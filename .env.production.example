# LaunchOS Production Environment
# Copy to .env.production and fill in your values

# ============================================================================
# REQUIRED
# ============================================================================

# Database
POSTGRES_USER=crm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=crm
DATABASE_URL=postgres://crm:CHANGE_ME_STRONG_PASSWORD@postgres:5432/crm

# App URL (your production domain)
APP_URL=https://yourdomain.com

# Auth
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
NODE_ENV=production

# AI (at least one required for Scout)
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_key
OPENAI_API_KEY=your_openai_key

# ============================================================================
# EMAIL (at least one required)
# ============================================================================

# Gmail OAuth (for sending via user's Gmail)
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your_secret

# Resend (fallback ESP for transactional email)
RESEND_API_KEY=re_your_key
EMAIL_FROM=noreply@yourdomain.com

# ============================================================================
# PAYMENTS
# ============================================================================

STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# ============================================================================
# CRON / BACKGROUND JOBS
# ============================================================================

# Secrets for cron endpoints (generate random strings)
CRON_SECRET=CHANGE_ME_RANDOM_STRING
SEQUENCE_PROCESS_SECRET=CHANGE_ME_RANDOM_STRING

# ============================================================================
# SECURITY
# ============================================================================

TENANT_DATA_ENCRYPTION=yes
TENANT_DATA_ENCRYPTION_FALLBACK_KEY=CHANGE_ME_RANDOM_32_CHAR_STRING

# ============================================================================
# OPTIONAL
# ============================================================================

# Cache
CACHE_STRATEGY=memory
CACHE_TTL=300000

# Search
OM_SEARCH_ENABLED=true

# Database pool
DB_POOL_MIN=5
DB_POOL_MAX=50

# Disable dev features
SELF_SERVICE_ONBOARDING_ENABLED=false
DEMO_MODE=false
NEXT_PUBLIC_UMES_DEVTOOLS=false
AUTO_SPAWN_WORKERS=true
AUTO_SPAWN_SCHEDULER=true
