# ==============================================================================
# CRM Platform — Production Environment Variables
# ==============================================================================
# Copy this file to .env and fill in ALL values before deploying.
# Every variable marked REQUIRED must be set for the app to function.
# Variables marked OPTIONAL have working defaults or enable optional features.
# ==============================================================================

# ── DATABASE (REQUIRED) ──────────────────────────────────────────────────────
# PostgreSQL 14+ with pgvector extension
POSTGRES_USER=crm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=crm
POSTGRES_PORT=5432
DATABASE_URL=postgres://crm:CHANGE_ME_STRONG_PASSWORD@localhost:5432/crm

# ── APP (REQUIRED) ───────────────────────────────────────────────────────────
# Must be your actual domain with https
APP_URL=https://crm.yourdomain.com
NODE_ENV=production

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Encryption key — generate with: openssl rand -hex 32
TENANT_DATA_ENCRYPTION=yes
TENANT_DATA_ENCRYPTION_FALLBACK_KEY=CHANGE_ME_GENERATE_32_CHAR_SECRET

# Admin notification email
ADMIN_EMAIL=you@yourdomain.com

# ── SIGNUP (REQUIRED) ────────────────────────────────────────────────────────
SELF_SERVICE_ONBOARDING_ENABLED=true
DEMO_MODE=false

# ── AI — GEMINI (REQUIRED for AI features) ───────────────────────────────────
# Get from: https://aistudio.google.com/apikey
# IMPORTANT: Enable billing (pay-as-you-go) to avoid rate limits
# Cost: ~$0.01-0.05 per AI call
AI_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GEMINI_API_KEY
# AI_MODEL=gemini-2.0-flash  # Optional: override default model

# ── EMAIL — RESEND (REQUIRED for email features) ─────────────────────────────
# Sign up: https://resend.com
# Steps:
#   1. Create account → Dashboard → API Keys → Create API Key
#   2. Domains → Add Domain → add DNS records (SPF, DKIM, DMARC)
#   3. Wait for domain verification (usually 5-15 minutes)
#   4. Set EMAIL_FROM to an address on your verified domain
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
EMAIL_FROM=hello@yourdomain.com
# This enables: signup verification emails, email compose, campaigns, invoice emails

# ── PAYMENTS — STRIPE (REQUIRED for payment features) ────────────────────────
# Sign up: https://stripe.com
# Steps:
#   1. Dashboard → Developers → API keys → copy Secret key
#   2. Dashboard → Developers → Webhooks → Add endpoint
#      URL: https://crm.yourdomain.com/api/stripe/webhook
#      Events: checkout.session.completed
#   3. Copy the Webhook signing secret
#   4. For testing use test mode keys (sk_test_...), switch to live for production
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET
# This enables: payment links, invoice payments, checkout pages, course purchases

# ── SMS — TWILIO (OPTIONAL — needed for text messaging) ──────────────────────
# Sign up: https://twilio.com
# Steps:
#   1. Console → Dashboard → copy Account SID and Auth Token
#   2. Console → Phone Numbers → Buy a Number (~$1/month)
#   3. Console → Phone Numbers → your number → Messaging webhook
#      URL: https://crm.yourdomain.com/api/sms/webhook
#      Method: POST
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# This enables: send/receive SMS from contact detail

# ── GOOGLE CALENDAR (OPTIONAL — needed for calendar sync) ────────────────────
# Set up: https://console.cloud.google.com
# Steps:
#   1. Create project → APIs & Services → Library → enable "Google Calendar API"
#   2. APIs & Services → OAuth consent screen → configure (External, app name, scopes)
#      Add scopes: calendar.readonly, calendar.events
#   3. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#      Type: Web application
#      Authorized redirect URI: https://crm.yourdomain.com/api/google/callback
#   4. Copy Client ID and Client Secret
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
# This enables: Google Calendar sync, availability blocking on booking pages

# ── WORKERS & QUEUES ─────────────────────────────────────────────────────────
AUTO_SPAWN_WORKERS=true
AUTO_SPAWN_SCHEDULER=true
QUEUE_BASE_DIR=./.mercato/queue
# For production with Redis:
# CACHE_STRATEGY=redis
# CACHE_REDIS_URL=redis://localhost:6379
# QUEUE_STRATEGY=redis
# REDIS_URL=redis://localhost:6379

# ── SEARCH ────────────────────────────────────────────────────────────────────
OM_SEARCH_ENABLED=true
OM_SEARCH_MIN_LEN=3
OM_SEARCH_ENABLE_PARTIAL=true
OM_SEARCH_HASH_ALGO=sha256
OM_SEARCH_STORE_RAW_TOKENS=false

# ── CACHE ─────────────────────────────────────────────────────────────────────
CACHE_STRATEGY=sqlite
CACHE_SQLITE_PATH=./data/cache.db
CACHE_TTL=300000

# ── DATABASE POOLING ──────────────────────────────────────────────────────────
DB_POOL_MIN=5
DB_POOL_MAX=30
DB_POOL_IDLE_TIMEOUT=10000
DB_POOL_ACQUIRE_TIMEOUT=10000

# ── RATE LIMITING ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STRATEGY=memory

# ── UI ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_OM_EXAMPLE_INJECTION_WIDGETS_ENABLED=false
NEXT_PUBLIC_UMES_DEVTOOLS=false

# ── ENTERPRISE (not needed) ──────────────────────────────────────────────────
OM_ENABLE_ENTERPRISE_MODULES=false
OM_ENABLE_ENTERPRISE_MODULES_SSO=false

# ── AUDIT LOGS ────────────────────────────────────────────────────────────────
AUDIT_LOGS_CORE_RETENTION_DAYS=30
AUDIT_LOGS_NON_CORE_RETENTION_HOURS=24
